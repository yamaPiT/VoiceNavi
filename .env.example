#------------------------------------------------------------------------------
# 開発用環境変数テンプレート (.env.example)
#
# 新規プロジェクト開始時:
# 1. このファイルをコピーして `.env` を作成してください
# 2. 必要なAPIキーなどを `.env` ファイルに記述して使用します
#
# 注意:
# * 本番環境のシークレットキーをこのファイルに直接書き込まないでください
# * `.env` は `.gitignore` によってGitの管理から除外されます
#------------------------------------------------------------------------------

# Google Gemini API Key
GEMINI_API_KEY=""

# OpenAI API Key (必要な場合)
OPENAI_API_KEY=""

# Anthropic API Key (必要な場合)
ANTHROPIC_API_KEY=""

# API Base URLs (必要に応じてコメントアウトを外す)
# VITE_API_BASE_URL="http://localhost:8000"
